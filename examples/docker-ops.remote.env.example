# Пример переменных для dq.env в корне проекта (или экспорт в окружении).
# Файл dq.env в .gitignore — не коммитить.
# Полный шаблон YAML:  dq env
#
# Обязательно для удалённого режима (compose, deploy, …), если не задано в docker-ops.yaml:
REMOTE_SSH=user@server
REMOTE_PATH=/opt/myapp

# Опционально:
# SSH_IDENTITY=~/.ssh/id_ed25519
# RSYNC_EXTRA=--dry-run

# --- Деплой artifacts (образ + compose) ---
# DEPLOY_MODE=artifacts
# COMPOSE_FILE=docker-compose.image.yml
#
# С registry:
# DEPLOY_IMAGE=ghcr.io/youraccount/myapp:1.0.0
# DEPLOY_PUSH=1
#
# Без registry (локальный тег без «/») — save | ssh | load:
# DEPLOY_IMAGE=myapp:1.0.0
# DEPLOY_PUSH=1
# DEPLOY_SAVE_COMPRESS=0
# DEPLOY_SAVE_LOAD=1 или DEPLOY_USE_REGISTRY=0|1 при нестандартных именах образа
